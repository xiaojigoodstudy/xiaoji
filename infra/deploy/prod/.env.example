# Backend image tag
BACKEND_IMAGE=xiaoji/backend:0.1.0

# Java options
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# MySQL (external; when mysql is on same host but different compose stack, use host.docker.internal)
MYSQL_URL=jdbc:mysql://host.docker.internal:3306/xiaoji?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
MYSQL_USERNAME=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

# Redis (external; when redis is on same host but different compose stack, use host.docker.internal)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DATABASE=0

# Nginx
NGINX_HTTP_PORT=80
NGINX_ADMIN_H5_PORT=8081
NGINX_OFFICIAL_H5_PORT=8082
NGINX_MOBILE_APP_PORT=8083
