# Backend image tag
BACKEND_IMAGE=xiaoji/backend:0.1.0

# Java options
JAVA_OPTS=-Xms384m -Xmx1024m -XX:+UseG1GC -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# MySQL (external; recommended: deploy on data server B and use private IP)
MYSQL_URL=jdbc:mysql://10.0.0.12:3306/xiaoji?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
MYSQL_USERNAME=root
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD

# Redis (external; recommended: deploy on data server B and use private IP)
REDIS_HOST=10.0.0.12
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_DATABASE=0

# If MySQL/Redis are on the same host but another compose stack:
# MYSQL_URL=jdbc:mysql://host.docker.internal:3306/xiaoji?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
# REDIS_HOST=host.docker.internal

# Nginx
NGINX_HTTP_PORT=80
NGINX_ADMIN_H5_PORT=8081
NGINX_OFFICIAL_H5_PORT=8082
NGINX_MOBILE_APP_PORT=8083
