.page {
  padding: 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
}

.desc {
  margin-top: 12rpx;
  color: #334155;
  line-height: 1.6;
}

.btn {
  margin-top: 24rpx;
  background: #2563eb;
  color: #ffffff;
}

.result {
  margin-top: 16rpx;
  color: #111827;
  word-break: break-all;
}
